# =============================================================================
# SECURITY WARNING: NEVER commit your actual .env file to git!
# This file is a TEMPLATE only — replace all values with your own.
# Generate a FRESH hot wallet specifically for this bot.
# Do NOT use your main wallet. Only fund with what you can afford to lose.
# =============================================================================

# --- Wallet ---
PRIVATE_KEY_BASE58=YOUR_BASE58_PRIVATE_KEY_HERE
PUBLIC_KEY=YOUR_PUBLIC_KEY_HERE

# --- Network (devnet for testing, mainnet for production) ---
NETWORK=mainnet

# --- Helius RPC (free tier: https://helius.dev) ---
# Get a MAINNET key from helius.dev — free tier is enough
HELIUS_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_HELIUS_API_KEY
HELIUS_WSS_URL=wss://mainnet.helius-rpc.com/?api-key=YOUR_HELIUS_API_KEY

# --- Fallback public RPC (used if Helius fails) ---
FALLBACK_RPC_URL=https://api.mainnet-beta.solana.com
FALLBACK_WSS_URL=wss://api.mainnet-beta.solana.com

# --- Jupiter Aggregator (free) ---
JUPITER_API_URL=https://quote-api.jup.ag/v6

# --- RugCheck (free tier: https://rugcheck.xyz) ---
RUGCHECK_API_URL=https://api.rugcheck.xyz/v1

# --- Birdeye (free tier: https://birdeye.so) ---
BIRDEYE_API_URL=https://public-api.birdeye.so
BIRDEYE_API_KEY=YOUR_BIRDEYE_API_KEY

# --- Twitter/X Social (optional, skip if you don't have one) ---
TWITTER_API_KEY=

# --- Telegram Alerts (optional but recommended) ---
TELEGRAM_BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN
TELEGRAM_CHAT_ID=YOUR_TELEGRAM_CHAT_ID

# --- Bot Modes ---
PAPER_TRADE_MODE=True
AGGRESSIVE_MODE=False
MIN_DEPOSIT_MODE=True
# Set to True to instantly sell all open positions (emergency use only)
EMERGENCY_SELL_ALL=False
